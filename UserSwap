<script>
(function() {
  // Check for enrolled status first
  setTimeout(function() {
    const pageText = document.body.innerText || "";
    // If it finds "Continue training" or "See progress", it shows the dashboard
    const isEnrolled = pageText.includes("Continue training") || pageText.includes("See progress");

    if (isEnrolled) {
      document.getElementById('enrolled-view').style.display = 'block';
      document.getElementById('public-view').style.display = 'none';
      runDashboardLogic(); 
    } else {
      document.getElementById('public-view').style.display = 'block';
      document.getElementById('enrolled-view').style.display = 'none';
    }
  }, 500);

  function runDashboardLogic() {
    // ==========================================
    // THE DATA DICTIONARY: 14-Week Module Data
    // ==========================================
    const courseData = [
      { 
        description: "Module 1: Orientation and Introduction to the Transformational Entrepreneurship Lab Series.", 
        notes: "N/A - First Session!" 
      },
      { 
        description: "Module 2 - Envisioning, Ideation, & Creating Vision: Introduction to brainstorming and creating a strong vision for your business.", 
        notes: "Review notes and takeaways from last week's orientation." 
      },
      { 
        description: "Module 3 - Defining Your Target Market & Customers: Learn how to identify and define your ideal customer base.", 
        notes: "Key takeaways from last week's ideation and vision exercises." 
      },
      { 
        description: "Module 4 - Developing Strong Value Propositions: Focus on crafting compelling value propositions for your target audience.", 
        notes: "Ensure your target market definitions from last week are clear." 
      },
      { 
        description: "Module 5 - Minimal Viable Product (MVP): Steps and strategies for developing and testing your MVP.", 
        notes: "Review feedback on the value propositions you drafted last week." 
      },
      { 
        description: "Module 6 - Essential Marketing & Advertising Strategy: Overview of basic marketing channels and advertising tactics.", 
        notes: "Think about how your MVP ties into the marketing concepts discussed." 
      },
      { 
        description: "Module 7 - Sales and Customer Service Foundations: Building the foundations for effective sales and excellent customer service.", 
        notes: "Review last week's marketing strategies and how they transition into sales." 
      },
      { 
        description: "Module 8 - Key Financial Concepts For Running Your Business: Introduction to the basic financial metrics and concepts you need to know.", 
        notes: "Keep customer service and sales foundations in mind as we pivot to financials." 
      },
      { 
        description: "Module 9 - Revenue Models, Budgeting, and Funding: Deep dive into pricing models, creating a budget, and exploring funding options.", 
        notes: "Review the basic financial terms and concepts from last week." 
      },
      { 
        description: "Module 10 - Developing a 3-Year Business Plan: Structuring and developing a comprehensive 3-year roadmap.", 
        notes: "Ensure your revenue models and budgets are ready to plug into the business plan." 
      },
      { 
        description: "Module 11 - Leadership and Culture: Exploring the importance of leadership styles and building a strong company culture.", 
        notes: "Reflect on the long-term vision established in last week's 3-year business plan." 
      },
      { 
        description: "Module 12 - Developing an Effective Pitch Deck 1: Part 1 of creating a compelling pitch deck for stakeholders and investors.", 
        notes: "Review leadership and culture concepts to incorporate into your team slide." 
      },
      { 
        description: "Module 13 - Developing an Effective Pitch Deck 2: Part 2 of pitching—refining, formatting, and practicing your presentation.", 
        notes: "Implement feedback from the initial pitch deck drafts created last week." 
      },
      { 
        description: "Module 14 - Magnifi Shark Tank: Final presentations! Pitch your business in the Magnifi Shark Tank.", 
        notes: "Apply the final polish to your pitch decks based on last week's practice session." 
      }
    ];

    const startDate = new Date("2026-02-17T18:30:00-06:00"); 
    const totalWeeks = 14;
    const now = new Date(); 
    
    const activeContainer = document.getElementById('activeSessionContainer');
    const futureContainer = document.getElementById('futureContainer');
    const progressBar = document.getElementById('progressBar');
    const progressText = document.getElementById('progressText');

    let activeFound = false;

    for (let i = 0; i < totalWeeks; i++) {
      const sessionDate = new Date(startDate);
      sessionDate.setDate(startDate.getDate() + (i * 7)); 
      
      const nextSessionDate = new Date(sessionDate);
      nextSessionDate.setDate(nextSessionDate.getDate() + 7);
      
      const isPast = now >= nextSessionDate;
      const isActive = now >= sessionDate && now < nextSessionDate;
      const isFuture = now < sessionDate;

      const dateLabel = sessionDate.toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
      const weekData = courseData[i] || { description: "TBD", notes: "TBD" };

      if (isActive) {
        activeFound = true;
        activeContainer.innerHTML = `
          <div class="active-session">
            <div class="active-header">
              <div class="active-title">Session ${i + 1}</div>
              <span class="status-badge">This Week</span>
            </div>
            <div class="session-details">
              <div class="detail-item"><strong>📝 Description:</strong> <br>${weekData.description}</div>
              <div class="detail-item"><strong>⏪ Notes from Session ${i === 0 ? 'Orientation' : i}:</strong> <br>${weekData.notes}</div>
            </div>
          </div>
        `;
      } else if (isFuture) {
        futureContainer.innerHTML += `
          <div class="future-session">
            <strong>Session ${i + 1}</strong>
            <span>${dateLabel} @ 6:30 PM</span>
          </div>
        `;
      }
    }

    if (!activeFound) {
      if (now < startDate) {
        activeContainer.innerHTML = `<div class="active-session" style="text-align:center;"><strong>Course starts on ${startDate.toLocaleDateString('en-US')}!</strong></div>`;
      } else {
        activeContainer.innerHTML = `<div class="active-session" style="text-align:center;"><strong>Course Complete! 🎉</strong></div>`;
      }
    }

    const timePassed = now - startDate;
    const weeksPassed = Math.max(0, Math.min(totalWeeks, timePassed / (1000 * 60 * 60 * 24 * 7)));
    const percent = Math.round((weeksPassed / totalWeeks) * 100);
    
    progressBar.style.width = percent + "%";
    progressText.innerText = `Currently on Week ${Math.floor(weeksPassed) + 1} of 14`;

    document.getElementById('toggleBtn').addEventListener('click', function() {
      if (futureContainer.style.display === 'flex') {
        futureContainer.style.display = 'none';
        this.innerText = '▼ Show Upcoming Schedule';
      } else {
        futureContainer.style.display = 'flex';
        this.innerText = '▲ Hide Upcoming Schedule';
      }
    });
  }
})();
</script>
